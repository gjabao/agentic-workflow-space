# DO Architecture - Environment Variables Template
# Copy to .env and add your actual API keys

# Apify API (for job scraping with Indeed)
APIFY_API_KEY=your_apify_api_key_here
# Get your key from: https://console.apify.com/account/integrations

# RapidAPI (for fast Google Search - decision maker & company website finding)
RAPIDAPI_KEY=your_rapidapi_key_here
# Get your key from: https://rapidapi.com/account/credentials
# Subscribe to: https://rapidapi.com/herosAPI/api/google-search116

# AnyMailFinder API (for email finding)
ANYMAILFINDER_API_KEY=your_anymailfinder_key_here
# Get your key from: https://anymailfinder.com/

# Azure OpenAI (for personalized email generation)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Apollo.io API (if using Apollo scraping)
# APOLLO_API_KEY=your_apollo_api_key_here

# Google API (OAuth2)
# Note: credentials.json and token.json should be placed in root directory

# ── Shopify (Beauty Connect Shop workflows) ──────────────────────────────────
SHOPIFY_STORE_URL=beautyconnectshop.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxx       # Preferred: Admin API access token
SHOPIFY_API_KEY=your_api_key_here         # Alternative: API key (private app)
SHOPIFY_API_SECRET=your_api_secret_here   # Alternative: API secret (private app)

# ── Anthropic Claude (blog section writing) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx            # Get from: console.anthropic.com

# ── Klaviyo (quiz email capture + auto-send results) ──────────────────────────
KLAVIYO_API_KEY=pk_xxxxx                 # Private API key (for server-side: list/template creation)
KLAVIYO_PUBLIC_KEY=xxxxxx                # Site ID / public key (for client-side: quiz tracking)
# Get both from: Klaviyo > Settings > API Keys

# ── Fal.ai (AI image generation for email templates) ────────────────────────
FAL_KEY=fal_xxxxx                      # Get from: https://fal.ai/dashboard/keys
# Used by: execution/fal_image_generator.py (Recraft V3 + Bria Product Shot)

# ── OpenAI (gpt-image-1 generation + editing for blog posts) ─────────────────
OPENAI_API_KEY=sk-xxxxx                # Get from: https://platform.openai.com/api-keys
# Used by: execution/publish_blog_to_shopify.py (featured image + stock/product redesign)

# ── Pexels (free stock photos for blog posts) ───────────────────────────────
PEXELS_API_KEY=xxxxx                   # Get from: https://www.pexels.com/api/new/
# Used by: execution/publish_blog_to_shopify.py (ingredient/lifestyle stock photos)

# Database Credentials (if needed)
# DATABASE_URL=your_database_url_here

# Email Configuration (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password_here
