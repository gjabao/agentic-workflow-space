# DO Architecture - Git Ignore Rules

# ============================================================================
# SECRETS & CREDENTIALS — NEVER COMMIT
# ============================================================================
.env
.env.*
*.key
*.pem
*.p12
credentials.json
token.json
*.pickle
.modal_webhook_url

# ============================================================================
# GENERATED & TEMPORARY FILES
# ============================================================================
.tmp/
active/tmp/
active/leads/
*.tmp
*.temp

# ============================================================================
# DATA FILES (generated outputs)
# ============================================================================
*.csv

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
env/
ENV/

# ============================================================================
# NODE
# ============================================================================
node_modules/
package-lock.json

# ============================================================================
# IDE & OS
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# LOGS
# ============================================================================
*.log
logs/

# ============================================================================
# SPECIFIC EXCLUSIONS
# ============================================================================
ONBOARDING_SETUP_STATUS.md
.github/workflows/daily-monitor.yml
